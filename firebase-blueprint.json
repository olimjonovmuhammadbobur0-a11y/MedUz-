{
  "entities": {
    "User": {
      "title": "User",
      "description": "Represents a user in the system",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "description": "User email" },
        "role": { "type": "string", "description": "User role (admin, user)" }
      },
      "required": ["uid", "email", "role"]
    },
    "Mnemonic": {
      "title": "Mnemonic",
      "description": "Medical mnemonic",
      "type": "object",
      "properties": {
        "category": { "type": "string" },
        "title": { "type": "string" },
        "mnemonic": { "type": "string" },
        "explanation": { "type": "string" }
      },
      "required": ["category", "title", "mnemonic", "explanation"]
    },
    "Question": {
      "title": "Question",
      "description": "Quiz question",
      "type": "object",
      "properties": {
        "subject": { "type": "string" },
        "topic": { "type": "string" },
        "difficulty": { "type": "string" },
        "question": { "type": "string" },
        "options": { "type": "array", "items": { "type": "string" } },
        "correct": { "type": "number" },
        "explanation": { "type": "string" }
      },
      "required": ["subject", "topic", "difficulty", "question", "options", "correct", "explanation"]
    },
    "Symptom": {
      "title": "Symptom",
      "description": "Symptom checker data",
      "type": "object",
      "properties": {
        "symptoms": { "type": "array", "items": { "type": "string" } },
        "diagnosis": { "type": "string" },
        "redFlag": { "type": "boolean" }
      },
      "required": ["symptoms", "diagnosis", "redFlag"]
    },
    "Video": {
      "title": "Video",
      "description": "Educational video",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "duration": { "type": "string" },
        "category": { "type": "string" },
        "videoUrl": { "type": "string" },
        "available": { "type": "boolean" }
      },
      "required": ["title", "duration", "category", "videoUrl", "available"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient record",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "number" },
        "symptoms": { "type": "string" },
        "condition": { "type": "string" },
        "healthScore": { "type": "number" },
        "medications": { "type": "string" }
      },
      "required": ["name", "age", "symptoms", "condition", "healthScore", "medications"]
    },
    "Section": {
      "title": "Section",
      "description": "Library section",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "icon": { "type": "string" },
        "color": { "type": "string" }
      },
      "required": ["title", "content", "icon", "color"]
    },
    "Setting": {
      "title": "Setting",
      "description": "App setting",
      "type": "object",
      "properties": {
        "key": { "type": "string" },
        "value": { "type": "string" }
      },
      "required": ["key", "value"]
    },
    "Library": {
      "title": "Library",
      "description": "Library data",
      "type": "object",
      "properties": {
        "data": { "type": "object" }
      },
      "required": ["data"]
    },
    "QuizRequest": {
      "title": "QuizRequest",
      "description": "Request to retake a quiz",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "topic": { "type": "string" },
        "subject": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "number" }
      },
      "required": ["userId", "userEmail", "userName", "topic", "subject", "status", "createdAt"]
    },
    "Fanlar": {
      "title": "Fanlar",
      "description": "Subjects and topics data",
      "type": "object",
      "properties": {
        "data": { "type": "array" }
      },
      "required": ["data"]
    },
    "OSCEScenario": {
      "title": "OSCEScenario",
      "description": "OSCE scenario data",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "systemInstruction": { "type": "string" },
        "initialMessage": { "type": "string" },
        "patientInfo": { "type": "object" }
      },
      "required": ["title", "description", "systemInstruction", "initialMessage"]
    },
    "BattleSession": {
      "title": "BattleSession",
      "description": "A live Zakovat battle session",
      "type": "object",
      "properties": {
        "hostId": { "type": "string" },
        "testId": { "type": "string" },
        "roomCode": { "type": "string" },
        "status": { "type": "string", "enum": ["waiting", "active", "completed"] },
        "duration": { "type": "number" },
        "startTime": { "type": "number" },
        "endTime": { "type": "number" },
        "maxParticipants": { "type": "number" }
      },
      "required": ["hostId", "testId", "roomCode", "status", "duration"]
    },
    "BattleParticipant": {
      "title": "BattleParticipant",
      "description": "A participant/group in a battle session",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "userId": { "type": "string" },
        "groupName": { "type": "string" },
        "totalScore": { "type": "number" },
        "completedAt": { "type": "number" }
      },
      "required": ["sessionId", "groupName", "totalScore"]
    },
    "BattleAnswer": {
      "title": "BattleAnswer",
      "description": "An answer submitted by a participant",
      "type": "object",
      "properties": {
        "sessionId": { "type": "string" },
        "participantId": { "type": "string" },
        "userId": { "type": "string" },
        "questionId": { "type": "string" },
        "selectedOption": { "type": "string" },
        "isCorrect": { "type": "boolean" },
        "answeredAt": { "type": "number" }
      },
      "required": ["sessionId", "participantId", "userId", "questionId", "selectedOption", "isCorrect", "answeredAt"]
    },
    "HostPermission": {
      "title": "HostPermission",
      "description": "Permission and details for a user to host battles",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "subjectId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "revoked"] },
        "requestedAt": { "type": "number" },
        "updatedAt": { "type": "number" }
      },
      "required": ["firstName", "lastName", "subjectId", "status", "requestedAt"]
    },
    "BattleTest": {
      "title": "BattleTest",
      "description": "A test created for Zakovat battles",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subjectId": { "type": "string" },
        "createdBy": { "type": "string" },
        "isPublished": { "type": "boolean" },
        "timeLimit": { "type": "number" }
      },
      "required": ["title", "description", "subjectId", "createdBy", "isPublished", "timeLimit"]
    },
    "BattleQuestion": {
      "title": "BattleQuestion",
      "description": "A question for a Zakovat test",
      "type": "object",
      "properties": {
        "testId": { "type": "string" },
        "text": { "type": "string" },
        "imageUrl": { "type": "string" },
        "type": { "type": "string", "enum": ["single", "multiple", "boolean", "text"] },
        "options": { "type": "array", "items": { "type": "string" } },
        "correctAnswer": { "type": "string" },
        "points": { "type": "number" },
        "orderIndex": { "type": "number" }
      },
      "required": ["testId", "text", "type", "correctAnswer", "points", "orderIndex"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "User" },
      "description": "User profiles"
    },
    "/mnemonics/{mnemonicId}": {
      "schema": { "$ref": "Mnemonic" },
      "description": "Mnemonics"
    },
    "/questions/{questionId}": {
      "schema": { "$ref": "Question" },
      "description": "Questions"
    },
    "/symptoms/{symptomId}": {
      "schema": { "$ref": "Symptom" },
      "description": "Symptoms"
    },
    "/videos/{videoId}": {
      "schema": { "$ref": "Video" },
      "description": "Videos"
    },
    "/patients/{patientId}": {
      "schema": { "$ref": "Patient" },
      "description": "Patients"
    },
    "/sections/{sectionId}": {
      "schema": { "$ref": "Section" },
      "description": "Sections"
    },
    "/settings/{settingId}": {
      "schema": { "$ref": "Setting" },
      "description": "Settings"
    },
    "/library/{libraryId}": {
      "schema": { "$ref": "Library" },
      "description": "Library data"
    },
    "/quizRequests/{requestId}": {
      "schema": { "$ref": "QuizRequest" },
      "description": "Quiz retake requests"
    },
    "/fanlar/{fanlarId}": {
      "schema": { "$ref": "Fanlar" },
      "description": "Subjects and topics"
    },
    "/osce_scenarios/{scenarioId}": {
      "schema": { "$ref": "OSCEScenario" },
      "description": "OSCE scenarios"
    },
    "/battle_sessions/{sessionId}": {
      "schema": { "$ref": "BattleSession" },
      "description": "Live Zakovat battle sessions"
    },
    "/battle_participants/{participantId}": {
      "schema": { "$ref": "BattleParticipant" },
      "description": "Participants in Zakovat battles"
    },
    "/battle_answers/{answerId}": {
      "schema": { "$ref": "BattleAnswer" },
      "description": "Answers submitted in Zakovat battles"
    },
    "/host_permissions/{userId}": {
      "schema": { "$ref": "HostPermission" },
      "description": "Permissions for users to host battles"
    },
    "/battle_tests/{testId}": {
      "schema": { "$ref": "BattleTest" },
      "description": "Tests for Zakovat battles"
    },
    "/battle_questions/{questionId}": {
      "schema": { "$ref": "BattleQuestion" },
      "description": "Questions for Zakovat tests"
    }
  }
}
