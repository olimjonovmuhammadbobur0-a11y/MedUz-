rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (Firebase Auth UID)
    // Fields:
    //   - uid: string (required) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - role: string (required) - User role (admin, user)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        ((exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        ((request.auth.token.email == "muhammadboburolimjonov2@gmail.com" || request.auth.token.email == "olimjonovmuhammadbobur0@gmail.com") && request.auth.token.email_verified == true));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /leaderboard/{userId} {
      allow read: if true;
      allow write: if isOwner(userId) || isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && request.resource.data.role == 'user';
      allow update: if (isOwner(userId) && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role'])) || isAdmin();
    }

    match /quizRequests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /mnemonics/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /questions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /symptoms/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /videos/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /patients/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /sections/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /library/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /osce_scenarios/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fanlar/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /news/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /journals/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /messages/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /duels/{duelId} {
      allow read: if isAuthenticated() && (resource.data.challengerId == request.auth.uid || resource.data.opponentId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.challengerId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.challengerId == request.auth.uid || resource.data.opponentId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Zakovat Bellashuvi Rules
    match /battle_tests/{testId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /battle_questions/{questionId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /battle_sessions/{sessionId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.hostId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.hostId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /battle_participants/{participantId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    match /battle_answers/{answerId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /host_permissions/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && request.auth.uid == userId && request.resource.data.status == 'pending';
      allow update: if isAdmin() || (isAuthenticated() && request.auth.uid == userId && request.resource.data.status == 'pending');
      allow delete: if isAdmin();
    }
  }
}
